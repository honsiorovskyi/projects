# vim:ft=bash

p() {
  local target
  target=$(pgo --print "$@")
  if [[ -n "$target" ]]; then
    cd "$target" || return 1
  fi
}

pn() {
  local target
  target=$(pnew --print "$@")
  if [[ -n "$target" ]]; then
    cd "$target" || return 1
  fi
}

pp() {
  local target
  target=$(pauto --print "$@")
  if [[ -n "$target" ]]; then
    cd "$target" || return 1
    if [[ -n "$PROJECTS_AUTO_CMD" ]]; then
      $PROJECTS_AUTO_CMD
    fi
  fi
}

alias pa='padd'
