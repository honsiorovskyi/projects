# vim:ft=bash

p() {
  local target
  target=$(pauto --print "$@")
  if [[ -n "$target" ]]; then
    cd "$target" || return 1
    if [[ -n "${PROJECTS_AUTO_CMD:-}" ]]; then
      $PROJECTS_AUTO_CMD
    fi
  fi
}

pp() {
  local target
  target=$(pgo --print "$@")
  if [[ -n "$target" ]]; then
    cd "$target" || return 1
  fi
}

alias pa='padd'
